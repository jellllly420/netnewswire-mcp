{
  "name": "@jellllly/netnewswire-mcp",
  "version": "0.1.2",
  "description": "MCP server for NetNewsWire — interact with your RSS feeds from Claude",
  "type": "module",
  "bin": {
    "netnewswire-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "bundle": "node --input-type=module -e \"import{build}from'esbuild';build({entryPoints:['dist/index.js'],bundle:true,platform:'node',format:'esm',outfile:'dist/bundle.js',banner:{js:'#!/usr/bin/env node'}})\"",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "netnewswire",
    "rss",
    "claude",
    "applescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jellllly420/netnewswire-mcp"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.4",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
